# DEEP breach variant: hold gone AND available insufficient. The buyer pays what exists
# (available 50000 of the 60000 owed), SETTLEFAULT reports uncovered=10000e8, and the seller is
# credited only the 50000 actually paid -- money is never invented; the fault names the victim
# and the exact discrepancy for operator repair.
CLOCK 1000
DEPOSIT u=200 asset=0 amt=100000.0
DEPOSIT u=100 asset=1 amt=1.0
HOLD u=200 order=22 asset=0 amt=60000.0
HOLD u=100 order=11 asset=1 amt=1.0
RELEASE order=22 u=200
WITHDRAW u=200 asset=0 amt=50000.0
TRADE tradeId=1 market=1 takerOrder=22 takerUser=200 makerOrder=11 makerUser=100 px=60000.0 qty=1.0 takerBuy=1
