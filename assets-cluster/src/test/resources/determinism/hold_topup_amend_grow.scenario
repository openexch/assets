# Amend-grow: a buyer raises an order's USD reservation by topping up the SAME orderId — the OMS posts
# the amend's hold DELTA under order=2, so locked SUMS rather than the hold being overwritten. A partial
# fill then draws from the enlarged hold and TERMINAL releases the residual on both sides.
CLOCK 1000
DEPOSIT u=100 asset=1 amt=1.0
DEPOSIT u=200 asset=0 amt=60000.0
HOLD order=1 u=100 asset=1 amt=1.0
HOLD order=2 u=200 asset=0 amt=30000.0
HOLD order=2 u=200 asset=0 amt=30000.0
TRADE tradeId=1 market=1 takerOrder=2 takerUser=200 makerOrder=1 makerUser=100 px=60000.0 qty=0.5 takerBuy=1
TERMINAL order=1 u=100
TERMINAL order=2 u=200
